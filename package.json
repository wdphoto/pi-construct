{
  "name": "the-construct",
  "version": "0.0.3",
  "private": true,
  "description": "A minimal Pi loadout menu for project-local packages.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "construct"
  ],
  "files": [
    "extensions/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/construct/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "smoke": "./scripts/smoke.sh",
    "install-smoke": "./scripts/install-smoke.sh",
    "e2e-smoke": "./scripts/e2e-smoke.sh",
    "invalid-drift-smoke": "./scripts/invalid-drift-smoke.sh"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
