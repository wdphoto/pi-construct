{
  "name": "pi-construct",
  "version": "0.0.14",
  "description": "A minimal Pi loadout menu for project-local packages.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "construct"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wdphoto/pi-construct.git"
  },
  "bugs": {
    "url": "https://github.com/wdphoto/pi-construct/issues"
  },
  "homepage": "https://github.com/wdphoto/pi-construct#readme",
  "files": [
    "extensions/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/construct/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "check:hygiene": "tsc --noEmit --noUnusedLocals --noUnusedParameters --pretty false",
    "pack:dry-run": "npm pack --dry-run",
    "release:verify": "npm run check && npm run pack:dry-run",
    "smoke:all": "npm run smoke && npm run e2e-smoke && npm run install-smoke && npm run invalid-drift-smoke",
    "prepublishOnly": "npm run release:verify",
    "smoke": "./scripts/smoke.sh",
    "install-smoke": "./scripts/install-smoke.sh",
    "e2e-smoke": "./scripts/e2e-smoke.sh",
    "invalid-drift-smoke": "./scripts/invalid-drift-smoke.sh"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
