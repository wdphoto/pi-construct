{
  "name": "the-construct",
  "version": "0.0.0",
  "private": true,
  "description": "A global Pi extension for loading project-local Pi resources.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
